---
layout: default
---

<div class="post">
  <article>
    {{ content }}
  </article>
</div>

<div class="row mt-3">
  {% for project in page.projects %}
    
    {% if project.separator %}
      <div class="col-12 mt-5 mb-3">
        <h3>{{ project.title }}</h3>
        <hr />
      </div>
    
    {% else %}
      <div class="col-sm-12 col-md-6 mb-4">
        <div class="card hoverable">
          
          <div class="video-preview-wrapper">
            
            <div class="card-img-top position-relative video-preview-container"
                 style="overflow: hidden; aspect-ratio: 5 / 3; background-color: #f0f0f0; display: flex; align-items: center; justify-content: center;">
              
              <video
                class="preview-video"
                loop muted playsinline
                controlsList="nodownload"
                preload="metadata"
                oncontextmenu="return false;"
                {% if project.poster %}poster="{{ project.poster | relative_url }}"{% endif %}
                style="width: 100%; height: 100%; object-fit: contain;"
              >
                <source src="{{ project.video | relative_url }}" type="video/mp4">
              </video>
              
              <!-- Play/Pause Button -->
              <button class="video-control-btn play-btn" aria-label="Play video">
                <i class="fas fa-play"></i>
              </button>
              
              <!-- Expand Button -->
              <button class="video-expand-btn" data-toggle="modal" data-target="#videoModal{{ forloop.index }}" aria-label="Expand video">
                <i class="fas fa-expand"></i>
              </button>
            </div>
          </div>
          
          <div class="card-body p-3">
            
            <h5 class="card-title mb-1">{{ project.title }}</h5>
            
            {% if project.description %}
              <p class="card-text mt-2">{{ project.description }}</p>
            {% endif %}
            
            <div class="card-text text-center mt-2">
              {% if project.students.first %}
                {% for student in project.students %}
                  <h6 class="text-muted mb-1" style="font-size: 0.9rem;">
                    <i class="fas fa-user mr-1"></i> {{ student }}
                  </h6>
                {% endfor %}
              {% else %}
                <h6 class="text-muted mb-0">
                  <i class="fas fa-user mr-1"></i> {{ project.students }}
                </h6>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
      
      <div class="modal fade" id="videoModal{{ forloop.index }}" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-dialog-80w" role="document">
          <div class="modal-content clean-modal-content">
            
            <div class="modal-body clean-modal-body">
              
              <button type="button" class="clean-close-btn" data-dismiss="modal" aria-label="Close">
                <i class="fas fa-times"></i>
              </button>
              
              <video
                controls
                controlsList="nodownload"
                oncontextmenu="return false;"
                class="modal-media modal-video"
              >
                <source src="{{ project.video | relative_url }}" type="video/mp4">
                Your browser does not support the video tag.
              </video>
              
              <div class="modal-caption">
                <h5>{{ project.title }}</h5>
                {% if project.description %}
                  <p><small>{{ project.description }}</small></p>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      </div>
    {% endif %}
  
  {% endfor %}
</div>

<style>
.video-preview-container {
  background-color: #f0f0f0 !important;
  position: relative;
}

.preview-video {
  background-color: transparent;
}

.video-preview-wrapper {
  position: relative;
  cursor: default;
}

/* Play/Pause Button - Center */
.video-control-btn {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: rgba(0, 0, 0, 0.7);
  border: none;
  border-radius: 50%;
  width: 60px;
  height: 60px;
  color: white;
  font-size: 24px;
  cursor: pointer;
  transition: all 0.3s ease;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 1;
}

.video-control-btn:hover {
  background-color: rgba(0, 0, 0, 0.85);
  transform: translate(-50%, -50%) scale(1.1);
}

.video-control-btn:focus {
  outline: 2px solid #007bff;
  outline-offset: 2px;
}

/* Hide play button when playing and cursor not hovering */
.video-control-btn.playing {
  opacity: 0;
  pointer-events: none;
}

.video-preview-wrapper:hover .video-control-btn.playing {
  opacity: 1;
  pointer-events: auto;
}

/* Expand Button - Top Right */
.video-expand-btn {
  position: absolute;
  top: 12px;
  right: 12px;
  background-color: rgba(0, 0, 0, 0.6);
  border: none;
  border-radius: 4px;
  width: 40px;
  height: 40px;
  color: white;
  font-size: 16px;
  cursor: pointer;
  transition: all 0.3s ease;
  z-index: 11;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
}

.video-expand-btn:hover {
  background-color: rgba(0, 0, 0, 0.85);
  transform: scale(1.1);
}

.video-expand-btn:focus {
  outline: 2px solid #007bff;
  outline-offset: 2px;
}

/* Show expand button on hover */
.video-preview-wrapper:hover .video-expand-btn {
  opacity: 1;
  pointer-events: auto;
}

/* Modal video styling */
.modal-video {
  width: 100%;
  height: auto;
  max-height: 80vh;
  object-fit: contain;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const videoWrappers = document.querySelectorAll('.video-preview-wrapper');
  
  videoWrappers.forEach(wrapper => {
    const video = wrapper.querySelector('.preview-video');
    const playBtn = wrapper.querySelector('.video-control-btn');
    const playIcon = playBtn.querySelector('i');
    
    // Play/Pause functionality
    playBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      
      if (video.paused) {
        video.play();
        playIcon.classList.remove('fa-play');
        playIcon.classList.add('fa-pause');
        playBtn.classList.add('playing');
      } else {
        video.pause();
        playIcon.classList.remove('fa-pause');
        playIcon.classList.add('fa-play');
        playBtn.classList.remove('playing');
      }
    });
    
    // Update button when video ends (for non-looping or manual pause)
    video.addEventListener('pause', function() {
      if (!video.ended) {
        playIcon.classList.remove('fa-pause');
        playIcon.classList.add('fa-play');
        playBtn.classList.remove('playing');
      }
    });
    
    video.addEventListener('play', function() {
      playIcon.classList.remove('fa-play');
      playIcon.classList.add('fa-pause');
      playBtn.classList.add('playing');
    });
  });
  
  // Handle modal videos
  const modals = document.querySelectorAll('.modal');
  modals.forEach(modal => {
    modal.addEventListener('shown.bs.modal', function() {
      // Pause all preview videos when modal opens
      document.querySelectorAll('.preview-video').forEach(v => {
        v.pause();
        const wrapper = v.closest('.video-preview-wrapper');
        const btn = wrapper.querySelector('.video-control-btn');
        const icon = btn.querySelector('i');
        icon.classList.remove('fa-pause');
        icon.classList.add('fa-play');
        btn.classList.remove('playing');
      });
      
      // Don't auto-play modal video - user has full control
      const modalVideo = modal.querySelector('.modal-video');
      if (modalVideo) {
        modalVideo.currentTime = 0;
      }
    });
    
    modal.addEventListener('hidden.bs.modal', function() {
      // Pause modal video when closing
      const modalVideo = modal.querySelector('.modal-video');
      if (modalVideo) {
        modalVideo.pause();
        modalVideo.currentTime = 0;
      }
    });
  });
});
</script>