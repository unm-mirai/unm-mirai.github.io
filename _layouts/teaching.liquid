---
layout: default
---

<div class="post">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}</h1>
    {% if page.description %}
      <p class="post-description">{{ page.description }}</p>
    {% endif %}
  </header>

  <article>
    <div class="clearfix">
      {{ content }}
    </div>

    {% if site.data.teaching %}
      {% for course in site.data.teaching %}
        <div class="card mt-3" style="background-color: transparent; border: 1px solid var(--global-divider-color);">
          <div class="p-3">
            <div class="row">
              <div class="col-sm-10">
                <h5 class="card-title">
                  {% if course.url %}
                    {% if course.url contains '://' %}
                      <a href="{{ course.url }}" target="_blank" rel="noopener noreferrer">{{ course.title }}</a>
                    {% else %}
                      <a href="{{ course.url | relative_url }}">{{ course.title }}</a>
                    {% endif %}
                  {% else %}
                    {{ course.title }}
                  {% endif %}
                </h5>
                <h6 class="card-subtitle font-italic">{{ course.role }}</h6>
              </div>
              <div class="col-sm-2 text-left text-sm-right">
                <span class="badge badge-secondary font-weight-bold text-uppercase align-middle">
                  {{ course.code }}
                </span>
              </div>
            </div>

            {% if course.materials %}
              <ul class="card-text font-weight-light list-group list-group-flush mt-2">
                {% for item in course.materials %}
                  <li class="list-group-item" style="background-color: transparent; color: inherit; border-color: var(--global-divider-color);">
                    <div class="row">
                      <div class="col-sm-9">
                        {{ item.name }}
                      </div>
                      <div class="col-sm-3 text-left text-sm-right">
                        {% if item.syllabus %}
                          <a href="{{ item.syllabus | relative_url }}" target="_blank" rel="noopener noreferrer">syllabus</a>&nbsp;
                        {% endif %}
                        {% if item.showcase %}
                          <a href="{{ item.showcase | relative_url }}" target="_blank" rel="noopener noreferrer">showcase</a>&nbsp;
                        {% endif %}
                        {% if item.slides %}
                          <a href="{{ item.slides }}" target="_blank" rel="noopener noreferrer">slides</a>&nbsp;
                        {% endif %}
                        {% if item.video %}
                          <a href="{{ item.video }}" target="_blank" rel="noopener noreferrer">video</a>&nbsp;
                        {% endif %}
                        {% if item.notes %}
                          <a href="{{ item.notes }}" target="_blank" rel="noopener noreferrer">notes</a>
                        {% endif %}
                      </div>
                    </div>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    {% else %}
      {% endif %}
  </article>
</div>